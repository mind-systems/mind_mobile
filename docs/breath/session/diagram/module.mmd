flowchart TB
    classDef model fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#1b5e20
    classDef service fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#e65100
    classDef viewmodel fill:#e3f2fd,stroke:#2196f3,stroke-width:2px,color:#0d47a1
    classDef animation fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#4a148c
    classDef ui fill:#fce4ec,stroke:#e91e63,stroke-width:2px,color:#880e4f
    classDef stream fill:#ffebee,stroke:#f44336,stroke-width:2px,color:#b71c1c

    %% === СЛОЙ МОДЕЛЕЙ ===
    subgraph Models["📦 Models Layer"]
        direction TB
        ExerciseStep["<b>BreathStepDTO</b><br/>───<br/>phase: inhale/hold/exhale<br/>duration: int (тики)"]:::model
        ExerciseSet["<b>BreathExerciseDTO</b><br/>───<br/>steps: List&lt;BreathStepDTO&gt;<br/>restDuration: int<br/>repeatCount: int<br/>───<br/>cycleDuration: вычисляемое<br/>shape: circle/square/triangle<br/>isRestOnly: bool"]:::model
        BreathSession["<b>BreathSessionDTO</b><br/>───<br/>id: String<br/>description: String<br/>exercises: List&lt;BreathExerciseDTO&gt;"]:::model

        ExerciseSet -->|"содержит"| ExerciseStep
        BreathSession -->|"содержит"| ExerciseSet
    end

    %% === СЛОЙ СЕРВИСОВ ===
    subgraph Services["⚙️ Services Layer"]
        direction TB
        ITickService["<b>ITickService</b><br/>───<br/>Stream&lt;TickData&gt; tickStream<br/>───<br/>Генерирует метроном<br/>~1 тик в секунду"]:::service
        TickData["<b>TickData</b><br/>───<br/>intervalMs: int<br/>───<br/>Фактический интервал<br/>между тиками"]:::service
        IBreathSessionService["<b>IBreathSessionService</b><br/>───<br/>Future&lt;BreathSessionDTO&gt; getSession(id)<br/>───<br/>Загружает данные сессии"]:::service

        ITickService -->|"эмитит"| TickData
    end

    %% === СЛОЙ STATE MACHINE + VIEWMODEL ===
    subgraph ViewModelLayer["🎯 ViewModel Layer"]
        direction TB

        StateMachine["<b>BreathSessionStateMachine</b><br/>═══════════════<br/><b>Внутренние счётчики:</b><br/>_exerciseIndex<br/>_repeatCounter<br/>_cycleTick<br/>═══════════════<br/><b>Управление:</b><br/>pause() / resume() / complete()<br/>═══════════════<br/><b>Тик-обработчики:</b><br/>_onBreathTick()<br/>_onRestTick()<br/>═══════════════<br/><b>Переходы:</b><br/>_startRest(isExerciseChange?)<br/>_startNewCycle(isExerciseChange?)<br/>_advanceExercise()"]:::viewmodel

        StateMachineState["<b>BreathSessionStateMachineState</b><br/>───<br/>status: pause/breath/rest/complete<br/>phase: inhale/hold/exhale/rest<br/>exerciseIndex: int<br/>remainingTicks: int<br/>activeStepId: String?<br/>currentIntervalMs: int<br/>───<br/>resetReason: newCycle/rest/exerciseChange/null<br/>totalPhases: int<br/>currentPhaseIndex: int<br/>currentPhaseTotalDuration: int<br/>currentExerciseShape: SetShape?<br/>nextExerciseShape: SetShape?"]:::viewmodel

        BreathViewModel["<b>BreathViewModel</b><br/>═══════════════<br/><b>Async loading:</b><br/>initState() → getSession() → _setupEngine()<br/>SessionLoadState: loading → ready<br/>═══════════════<br/><b>Subscription:</b><br/>_stateMachineSubscription:<br/>  StateMachine.stateStream<br/>  → Riverpod state<br/>═══════════════<br/><b>Управление:</b><br/>pause() / resume() / complete()<br/>restartEngine() → _setupEngine(cached DTO)"]:::viewmodel

        BreathSessionState["<b>BreathSessionState</b><br/>───<br/>loadState: loading/ready/error<br/>status: pause/breath/rest/complete<br/>phase: inhale/hold/exhale/rest<br/>exerciseIndex: int<br/>remainingTicks: int<br/>currentIntervalMs: int<br/>timelineSteps: List&lt;TimelineStep&gt;<br/>activeStepId: String?<br/>───<br/>resetReason: newCycle/rest/exerciseChange/null<br/>totalPhases: int<br/>currentPhaseIndex: int<br/>currentPhaseTotalDuration: int<br/>currentExerciseShape: SetShape?<br/>nextExerciseShape: SetShape?"]:::stream

        StateMachine -->|"эмитит"| StateMachineState
        BreathViewModel -->|"проксирует"| StateMachine
        BreathViewModel -->|"эмитит Riverpod"| BreathSessionState
    end

    %% === СЛОЙ АНИМАЦИИ ===
    subgraph AnimationLayer["🎨 Animation Layer"]
        direction TB

        BreathMotionEngine["<b>BreathMotionEngine</b><br/>═══════════════<br/><b>Физика движения:</b><br/>_position: 0.0 → 1.0<br/>_currentVelocity<br/>_targetVelocity<br/>_phaseTargetPosition<br/>═══════════════<br/><b>Режимы:</b><br/>Accelerating → Linear<br/>Плавное достижение цели<br/>за remainingPhaseTicks<br/>═══════════════<br/><b>API:</b><br/>setActive(bool)<br/>setPhaseInfo(totalPhases, currentPhaseIndex)<br/>setRemainingPhaseTicks(int)<br/>setIntervalMs(int)<br/>resetPosition(double)<br/>───<br/>isActive: bool<br/>normalizedPosition: 0..1"]:::animation

        BreathShapeShifter["<b>BreathShapeShifter</b><br/>═══════════════<br/><b>Геометрия:</b><br/>_currentPoints: 120 точек<br/>_currentShape<br/>_morphProgress: 0..1<br/>═══════════════<br/><b>Формы:</b><br/>circle / square<br/>triangleUp / triangleDown<br/>═══════════════<br/><b>Морфинг:</b><br/>morphTo(shape) → анимация 800ms<br/>Прямоугольные: через Path<br/>С кругом: через interpolation<br/>═══════════════<br/><b>API:</b><br/>initialize(center, size, vsync)<br/>updateBounds(center, size)<br/>morphTo(SetShape)<br/>getCurrentPath() → Path<br/>getPointPosition(time) → Offset"]:::animation

        Coordinator["<b>BreathAnimationCoordinator</b><br/>═══════════════<br/><b>Оркестрация:</b><br/>Слушает BreathSessionState (Riverpod)<br/>Читает resetReason из state<br/>═══════════════<br/><b>Синхронизация:</b><br/>status → motionEngine.setActive()<br/>setPhaseInfo() при старте breath<br/>remainingTicks → setRemainingPhaseTicks()<br/>intervalMs → setIntervalMs()<br/>═══════════════<br/><b>Сброс:</b><br/>reset(): деактивирует motionEngine,<br/>  сбрасывает кэши состояния<br/>═══════════════<br/><b>Морфинг по resetReason в state:</b><br/>exerciseChange/rest → morphTo(shape)<br/>newCycle → resetPosition(0.0)"]:::animation

        OrbCoordinator["<b>OrbAnimationCoordinator</b><br/>═══════════════<br/><b>Оркестрация:</b><br/>Слушает BreathSessionState (Riverpod)<br/>Читает resetReason из state<br/>═══════════════<br/><b>Прогресс:</b><br/>inhale → lerp(min, max, phaseRaw)<br/>exhale → lerp(min, max, 1-phaseRaw)<br/>hold/rest/pause → frozen<br/>═══════════════<br/><b>maxProgress по форме:</b><br/>circle → 0.8, остальные → 1.0<br/>═══════════════<br/><b>По resetReason в state:</b><br/>обновляет maxProgress<br/>сбрасывает orbProgress → min<br/>═══════════════<br/><b>Выход:</b><br/>ValueNotifier&lt;double&gt; orbProgress"]:::animation

        LiveSessionCoordinator["<b>LiveSessionCoordinator</b><br/>═══════════════<br/><b>Lifecycle:</b><br/>первый resume → startSession()<br/>pause → pauseSession()<br/>resume из паузы → resumeSession()<br/>complete → endSession()<br/>═══════════════<br/><b>Телеметрия:</b><br/>phase/exerciseIndex changed<br/>→ _handleTelemetry(state)<br/>→ sendSample(phase, durationMs)"]:::animation

        Coordinator -->|"управляет"| BreathMotionEngine
        Coordinator -->|"управляет"| BreathShapeShifter
    end

    %% === СЛОЙ UI ===
    subgraph UILayer["🖼️ UI Layer"]
        direction TB

        BreathSessionScreen["<b>BreathSessionScreen</b><br/>═══════════════<br/><b>Создаёт (initState):</b><br/>BreathMotionEngine<br/>BreathShapeShifter<br/>BreathAnimationCoordinator<br/>OrbAnimationCoordinator<br/>LiveSessionCoordinator<br/>═══════════════<br/><b>Post-frame callback:</b><br/>coordinator.initialize(state)<br/>orbCoordinator.initialize(state)<br/>viewModel.initState() [async]<br/>═══════════════<br/><b>Управление:</b><br/>pause() / resume() / restartEngine()<br/>═══════════════<br/><b>Отображает:</b><br/>BreathShapeWidget<br/>EclipseOrb (ValueListenableBuilder)<br/>BreathTimelineWidget<br/>Кнопки управления"]:::ui

        BreathWidget["<b>BreathShapeWidget</b><br/>───<br/>ListenableBuilder:<br/>motionController + shapeController<br/>───<br/>LayoutBuilder:<br/>updateBounds() при resize<br/>───<br/>CustomPaint:<br/>BreathShapePainter"]:::ui

        BreathPainter["<b>BreathShapePainter</b><br/>═══════════════<br/><b>Рендеринг:</b><br/>1. Фигура (3 слоя):<br/>   - Outer glow<br/>   - Main stroke<br/>   - Inner highlight<br/>───<br/>2. Точка (4 слоя):<br/>   - Outer glow<br/>   - Mid glow<br/>   - Main circle<br/>   - Center highlight<br/>═══════════════<br/><b>Входы:</b><br/>shapeShifter.getCurrentPath()<br/>motionEngine.normalizedPosition"]:::ui

        BreathSessionScreen -->|"создаёт"| BreathWidget
        BreathWidget -->|"использует"| BreathPainter
    end

    %% === ПОТОКИ ДАННЫХ ===

    %% Модели → ViewModel
    BreathSession -.->|"загружается через service"| BreathViewModel

    %% Сервисы → StateMachine / ViewModel
    IBreathSessionService -->|"getSession()"| BreathViewModel
    ITickService -->|"tickStream"| StateMachine

    %% ViewModel → Coordinators
    BreathViewModel -->|"Riverpod state"| Coordinator
    BreathViewModel -->|"Riverpod state"| OrbCoordinator
    BreathViewModel -->|"Riverpod state"| LiveSessionCoordinator

    %% Coordinator → Animation
    Coordinator -->|"синхронизирует"| BreathMotionEngine
    Coordinator -->|"синхронизирует"| BreathShapeShifter

    %% OrbCoordinator → UI
    OrbCoordinator -.->|"orbProgress (ValueNotifier)"| BreathSessionScreen

    %% Animation → UI
    BreathMotionEngine -.->|"notifyListeners()"| BreathWidget
    BreathShapeShifter -.->|"notifyListeners()"| BreathWidget
    BreathWidget -->|"передаёт данные"| BreathPainter

    %% UI → ViewModel
    BreathSessionScreen -.->|"pause() / resume() / restartEngine()"| BreathViewModel
    BreathSessionScreen -.->|"читает Riverpod state"| BreathViewModel

    %% === ЛЕГЕНДА ===
    subgraph Legend["📋 Легенда"]
        direction LR
        L1["Модели данных"]:::model
        L2["Сервисы"]:::service
        L3["ViewModel / StateMachine"]:::viewmodel
        L4["Анимация"]:::animation
        L5["UI"]:::ui
        L6["Стримы"]:::stream
    end

    %% === КЛЮЧЕВЫЕ ПОТОКИ ===
    subgraph KeyFlows["🔄 Ключевые потоки"]
        direction TB
        Flow1["<b>1. Инициализация</b><br/>Screen создаёт MotionEngine + ShapeShifter + Coordinator<br/>→ post-frame: coordinator.initialize() + viewModel.initState()<br/>→ async: getSession() → _setupEngine() → StateMachine создаётся<br/>→ loadState: loading → ready → Coordinator синхронизируется"]
        Flow2["<b>2. Tick Loop</b><br/>TickService → StateMachine._onTick()<br/>→ stateStream → ViewModel._onEngineState()<br/>→ Riverpod state → Coordinator._onStateChanged()<br/>→ motionEngine.setPhaseInfo() / setRemainingPhaseTicks()"]
        Flow3["<b>3. Морфинг</b><br/>StateMachine._advanceExercise() / _startRest() / _startNewCycle()<br/>→ state.resetReason встроен в emit<br/>→ Riverpod state → Coordinator._onStateChanged()<br/>→ ShapeShifter.morphTo() + MotionEngine.resetPosition()"]
        Flow4["<b>4. Рестарт</b><br/>Screen: coordinator.reset() + orbCoordinator.reset()<br/>→ viewModel.restartEngine() → _setupEngine(cached DTO)<br/>→ новый StateMachine создаётся<br/>→ Coordinators видят breath → активируются"]
        Flow5["<b>5. Рендеринг фигуры</b><br/>MotionEngine/ShapeShifter.notifyListeners()<br/>→ BreathShapeWidget rebuild<br/>→ Painter рисует Path + точку"]
        Flow6["<b>6. Рендеринг орба</b><br/>TickService → StateMachine → ViewModel → Riverpod state<br/>→ OrbCoordinator._onStateChanged()<br/>→ orbProgress.value = shapeDimension * progress<br/>→ ValueListenableBuilder → EclipseOrb(size: ...)"]
    end
