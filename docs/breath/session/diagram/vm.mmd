flowchart TD
    classDef external fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#e65100
    classDef vm fill:#e3f2fd,stroke:#2196f3,stroke-width:2px,color:#0d47a1
    classDef machine fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#1b5e20
    classDef consumer fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#4a148c
    classDef stream fill:#ffebee,stroke:#f44336,stroke-width:2px,color:#b71c1c

    %% === Внешние зависимости ===
    ITickService["<b>ITickService</b><br/>tickStream"]:::external
    IBreathSessionService["<b>IBreathSessionService</b><br/>getSession(id): Future&lt;DTO&gt;"]:::external
    Screen["<b>BreathSessionScreen</b><br/>вызывает: pause / resume<br/>restartEngine / initState"]:::external

    %% === BreathViewModel ===
    subgraph VM["🎯 BreathViewModel (StateNotifier)"]
        direction TB

        initState["initState()<br/>───<br/>async: getSession() → DTO<br/>кэшируется в _sessionDTO<br/>→ _setupEngine(dto)"]:::vm

        setupEngine["_setupEngine(dto)<br/>───<br/>dispose() старого StateMachine<br/>создаёт новый StateMachine<br/>эмитит Riverpod state (ready)"]:::vm

        onEngineState["_onEngineState(state)<br/>───<br/>обновляет timelineSteps<br/>→ эмитит Riverpod state"]:::vm

        restartEngine["restartEngine()<br/>───<br/>_setupEngine(_sessionDTO!)<br/>использует кэшированный DTO"]:::vm
    end

    %% === StateMachine (создаётся внутри VM) ===
    subgraph SM["⚙️ BreathSessionStateMachine (создаётся в _setupEngine)"]
        direction LR
        SMState["stateStream<br/>Stream&lt;StateMachineState&gt;<br/>───<br/>Обогащённые поля:<br/>resetReason / totalPhases<br/>currentPhaseIndex<br/>currentPhaseTotalDuration<br/>currentExerciseShape<br/>nextExerciseShape"]:::machine
    end

    %% === Riverpod state ===
    RiverpodState["Riverpod State<br/>───<br/>BreathSessionState<br/>loadState / status / phase<br/>remainingTicks / timelineSteps<br/>resetReason / totalPhases<br/>currentPhaseIndex<br/>currentPhaseTotalDuration<br/>currentExerciseShape<br/>nextExerciseShape"]:::stream

    %% === Потребители ===
    Coordinator["<b>BreathAnimationCoordinator</b><br/>Слушает Riverpod state<br/>Читает resetReason из state"]:::consumer
    OrbCoordinator["<b>OrbAnimationCoordinator</b><br/>Слушает Riverpod state<br/>Читает resetReason из state"]:::consumer
    LiveCoordinator["<b>LiveSessionCoordinator</b><br/>Слушает Riverpod state<br/>lifecycle + телеметрия"]:::consumer

    %% === Потоки данных ===

    %% Загрузка
    IBreathSessionService -->|"async getSession()"| initState
    ITickService -->|"tickStream"| SM

    %% Инициализация
    Screen -->|"initState()"| initState
    initState -->|"загрузил DTO"| setupEngine
    setupEngine -->|"создаёт"| SM

    %% SM → VM → наружу
    SMState -->|"_stateMachineSubscription.listen()"| onEngineState
    onEngineState -->|"Riverpod emit"| RiverpodState

    %% Riverpod state → потребители
    RiverpodState -->|"Riverpod listener"| Coordinator
    RiverpodState -->|"Riverpod listener"| OrbCoordinator
    RiverpodState -->|"Riverpod listener"| LiveCoordinator

    %% Управление
    Screen -->|"pause() / resume() / complete()"| SM
    Screen -->|"restartEngine()"| restartEngine
    restartEngine -->|"_setupEngine(cached DTO)"| setupEngine
